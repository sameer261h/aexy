# Application Settings
APP_NAME=Aexy
DEBUG=false
API_V1_PREFIX=/api/v1

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aexy
DATABASE_ECHO=false

# GitHub OAuth Configuration
# Register a GitHub App at: https://github.com/settings/apps
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# GitHub API
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_OAUTH_URL=https://github.com/login/oauth

# Stripe Configuration
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Product/Price IDs (create in Stripe Dashboard or via API)
# Monthly prices
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_xxx
# Yearly prices (optional)
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_xxx

# Slack Integration
# Create a Slack App at: https://api.slack.com/apps
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_REDIRECT_URI=http://localhost:8000/api/v1/slack/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_id_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Microsoft OAuth (sign-in + Outlook Mail / Calendar via Graph)
# App registration: https://portal.azure.com/ (App registrations)
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
# Use 'common' for personal + work/school, 'organizations' for work-only,
# or a specific tenant GUID for single-tenant SSO.
MICROSOFT_TENANT_ID=common
MICROSOFT_AUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/microsoft/callback

FRONTEND_URL=http://localhost:3000

# LLM Configuration
# Supported providers: claude, gemini, ollama, openrouter, deepseek
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key
# OpenRouter (API aggregator for 100+ models)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4
# Comma-separated fallback models (tried in order when primary is rate-limited)
OPENROUTER_FALLBACK_MODELS=google/gemini-2.0-flash,openai/gpt-4o,deepseek/deepseek-chat-v3,meta-llama/llama-3.1-70b-instruct
# DeepSeek (direct API, OpenAI-compatible)
# Get your API key from: https://platform.deepseek.com/api_keys
# To use DeepSeek, set LLM_PROVIDER=deepseek and LLM_MODEL=deepseek-chat (or deepseek-reasoner) above.
DEEPSEEK_API_KEY=your_deepseek_api_key
# Comma-separated fallback models (tried in order when primary is rate-limited)
DEEPSEEK_FALLBACK_MODELS=deepseek-reasoner

# Email Configuration
# Choose email provider: 'ses', 'smtp', or 'postmark'
EMAIL_PROVIDER=ses
EMAIL_NOTIFICATIONS_ENABLED=true

# AWS SES Configuration (when EMAIL_PROVIDER=ses)
# Get your AWS credentials from: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SES_REGION=us-east-1
SES_SENDER_EMAIL=noreply@yourdomain.com
SES_SENDER_NAME=Aexy

# Postmark Configuration (when EMAIL_PROVIDER=postmark)
# Get your tokens from: https://account.postmarkapp.com/servers
POSTMARK_SERVER_TOKEN=your_postmark_server_token
POSTMARK_ACCOUNT_TOKEN=your_postmark_account_token
POSTMARK_SENDER_EMAIL=noreply@yourdomain.com
POSTMARK_SENDER_NAME=Aexy
POSTMARK_TRANSACTIONAL_STREAM=outbound
POSTMARK_BROADCAST_STREAM=broadcast

# SMTP Configuration (when EMAIL_PROVIDER=smtp)
# Common SMTP providers:
# - Gmail: smtp.gmail.com (port 587, use app password)
# - SendGrid: smtp.sendgrid.net (port 587)
# - Mailgun: smtp.mailgun.org (port 587)
# - Amazon SES SMTP: email-smtp.<region>.amazonaws.com (port 587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_SENDER_EMAIL=your_email@gmail.com
SMTP_SENDER_NAME=Aexy

# Cloudflare R2 Storage Configuration (for assessment recordings)
# Get your R2 credentials from: https://dash.cloudflare.com/ -> R2 -> Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=your_bucket_name
R2_RECORDINGS_PREFIX=assessment-recordings

VAPID_PUBLIC_KEY=YOUR_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_PRIVATE_KEY
VAPID_CLAIMS_EMAIL=mailto:admin@example.com

# Platform Organization
# Set to a workspace UUID to enable auto-CRM contact + onboarding drip emails on signup
PLATFORM_ORG_ID=