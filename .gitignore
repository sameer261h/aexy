node_modules
.next
.build
.DS_Store

# Local-only generated files — Next.js rewrites the next-env.d.ts
# reference between dev (`.next/dev/types/...`) and prod
# (`.next/types/...`) builds, and the TypeScript incremental build
# info is per-machine. Both should not be committed.
frontend/next-env.d.ts
frontend/tsconfig.tsbuildinfo

# Auto-generated merged i18n files (run npm run i18n:merge to regenerate)
frontend/messages/en.json
frontend/messages/hi.json
__pycache__
.env
celerybeat-schedule
backend-rust

/gtm
/prds
.playwright-mcp
screenshots

# Playwright artifacts (regenerated each test run)
frontend/playwright-report/
frontend/test-results/
frontend/e2e/debug-screenshot*.png

# Test coverage output (regenerated each test run)
.coverage
backend/.coverage
htmlcov/

# AI test transcripts (regenerated by backend/tests/ai)
backend/tests/ai/.logs/

# Python packaging artifacts (regenerated by `uv pip install -e` / build tools)
*.egg-info/
**/*.egg-info/

# uv lockfiles for sub-projects (generated by local `uv run`, not committed)
mailagent/uv.lock

# Python virtualenvs
.venv/
**/.venv/

