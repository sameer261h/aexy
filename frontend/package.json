{
  "name": "aexy-frontend",
  "version": "0.8.56",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "i18n:merge": "node scripts/merge-messages.js",
    "prebuild": "npm run i18n:merge && node scripts/generate-changelog.mjs && node scripts/generate-docs.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:leave": "playwright test e2e/leave.spec.ts",
    "test:e2e:leave:headed": "playwright test e2e/leave.spec.ts --headed",
    "test:e2e:leave:ui": "playwright test e2e/leave.spec.ts --ui",
    "test:e2e:billing": "playwright test e2e/billing.spec.ts",
    "test:e2e:billing:headed": "playwright test e2e/billing.spec.ts --headed",
    "test:e2e:billing:ui": "playwright test e2e/billing.spec.ts --ui",
    "test:e2e:invoices": "playwright test e2e/admin-invoices.spec.ts",
    "test:e2e:invoices:headed": "playwright test e2e/admin-invoices.spec.ts --headed",
    "changelog": "node scripts/generate-changelog.mjs",
    "docs:gen": "node scripts/generate-docs.mjs",
    "schema:automation:precheck": "docker ps --filter name=aexy-backend --filter status=running --quiet | grep -q . || { echo 'Error: aexy-backend container is not running. Start it with: docker-compose up -d backend' >&2; exit 1; }",
    "schema:automation": "npm run -s schema:automation:precheck && docker exec aexy-backend python scripts/dump_automation_schema.py --out - > e2e/fixtures/automation-schema.generated.json",
    "schema:automation:check": "npm run -s schema:automation:precheck && docker cp e2e/fixtures/automation-schema.generated.json aexy-backend:/tmp/schema.json && docker exec aexy-backend python scripts/dump_automation_schema.py --check --out /tmp/schema.json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@icons-pack/react-simple-icons": "^13.8.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.17.0",
    "@tiptap/extension-code-block-lowlight": "^2.1.0",
    "@tiptap/extension-collaboration": "^2.1.0",
    "@tiptap/extension-collaboration-cursor": "^2.1.0",
    "@tiptap/extension-highlight": "^2.1.0",
    "@tiptap/extension-image": "^2.1.0",
    "@tiptap/extension-link": "^2.27.1",
    "@tiptap/extension-mention": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.1",
    "@tiptap/extension-table": "^2.1.0",
    "@tiptap/extension-table-cell": "^2.1.0",
    "@tiptap/extension-table-header": "^2.1.0",
    "@tiptap/extension-table-row": "^2.1.0",
    "@tiptap/extension-task-item": "^2.1.0",
    "@tiptap/extension-task-list": "^2.1.0",
    "@tiptap/extension-typography": "^2.1.0",
    "@tiptap/extension-underline": "^2.1.0",
    "@tiptap/pm": "^2.27.1",
    "@tiptap/react": "^2.27.1",
    "@tiptap/starter-kit": "^2.27.1",
    "@tiptap/suggestion": "^2.27.2",
    "@types/nprogress": "^0.2.3",
    "@xyflow/react": "^12.10.0",
    "autoprefixer": "^10.4.17",
    "axios": "^1.6.5",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "face-api.js": "^0.22.2",
    "framer-motion": "^12.24.0",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.14.0",
    "lowlight": "^3.0.0",
    "lucide-react": "^0.469.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "next-nprogress-bar": "^2.4.7",
    "nprogress": "^0.2.0",
    "postcss": "^8.4.33",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "react-markdown": "^9.1.0",
    "recharts": "^3.6.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.29.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.1",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.8.10",
    "y-prosemirror": "^1.3.7",
    "y-websocket": "^1.5.0",
    "yjs": "^13.6.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.11.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "jsdom": "^24.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "node-fetch": "^2.7.0"
  }
}
