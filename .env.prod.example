# Aexy Production Environment Variables
# Copy this file to .env.prod and fill in the values

# =============================================================================
# REQUIRED - Must be set before deployment
# =============================================================================

# Database credentials (use strong passwords!)
POSTGRES_USER=aexy
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=aexy

# Schema changes must come from SQL migrations, not app startup create_all().
SCHEMA_CREATE_ALL=false

# Application secret key (generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# Shared HMAC secret for backend -> mailagent internal calls
# Generate with: openssl rand -hex 32
MAILAGENT_INTERNAL_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# AI Provider API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Object storage (RustFS) — required for file uploads (task attachments,
# recordings, compliance docs). Used as both S3 credentials and the
# RustFS root credentials inside the bundled rustfs container.
RUSTFS_ROOT_USER=aexy-admin
RUSTFS_ROOT_PASSWORD=CHANGE_ME_TO_A_STRONG_STORAGE_PASSWORD

# Public URL the browser uses to fetch uploaded files. Nginx proxies
# /storage/ → rustfs:9000. Set this to your public origin + /storage.
S3_PUBLIC_ENDPOINT_URL=https://server.aexy.io/storage

# =============================================================================
# OPTIONAL - Defaults are usually fine
# =============================================================================

# LLM Configuration
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash

# Frontend API URL (use /api/v1 when behind nginx proxy)
NEXT_PUBLIC_API_URL=/api/v1

# Frontend billing — flip to "true" once Stripe is set up to re-enable
# in-product checkout and the customer portal. While disabled, paid-tier
# CTAs open a mailto to sales@aexy.io for offline billing.
NEXT_PUBLIC_STRIPE_ENABLED=false

# Public app URLs
FRONTEND_URL=https://aexy.io
BACKEND_URL=https://server.aexy.io

# Microsoft OAuth / Graph
# Azure app registration redirect URIs:
# - https://server.aexy.io/api/v1/auth/microsoft/callback
# - https://server.aexy.io/api/v1/booking/calendars/callback/microsoft
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=common
MICROSOFT_AUTH_REDIRECT_URI=https://server.aexy.io/api/v1/auth/microsoft/callback
MICROSOFT_REDIRECT_URI=https://server.aexy.io/api/v1/booking/calendars/callback/microsoft

# Backup retention (days)
BACKUP_RETENTION_DAYS=7

# =============================================================================
# SSL/DOMAIN (configure when ready for HTTPS)
# =============================================================================

# Your domain name (uncomment and set when ready)
# DOMAIN=your-domain.com
