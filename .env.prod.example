# Aexy Production Environment Variables
# Copy this file to .env.prod and fill in the values

# =============================================================================
# REQUIRED - Must be set before deployment
# =============================================================================

# Database credentials (use strong passwords!)
POSTGRES_USER=aexy
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=aexy

# Application secret key (generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# AI Provider API Key
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# OPTIONAL - Defaults are usually fine
# =============================================================================

# LLM Configuration
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash

# Frontend API URL (use /api/v1 when behind nginx proxy)
NEXT_PUBLIC_API_URL=/api/v1

# Public app URLs
FRONTEND_URL=https://aexy.io
BACKEND_URL=https://server.aexy.io

# Microsoft OAuth / Graph
# Azure app registration redirect URIs:
# - https://server.aexy.io/api/v1/auth/microsoft/callback
# - https://server.aexy.io/api/v1/booking/calendars/callback/microsoft
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=common
MICROSOFT_AUTH_REDIRECT_URI=https://server.aexy.io/api/v1/auth/microsoft/callback
MICROSOFT_REDIRECT_URI=https://server.aexy.io/api/v1/booking/calendars/callback/microsoft

# Backup retention (days)
BACKUP_RETENTION_DAYS=7

# =============================================================================
# SSL/DOMAIN (configure when ready for HTTPS)
# =============================================================================

# Your domain name (uncomment and set when ready)
# DOMAIN=your-domain.com
